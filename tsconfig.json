{
    "compilerOptions": {
        "baseUrl": ".",
        "paths": {
            "@/*": ["resources/js/*"],
            "ziggy-js": ["./vendor/tightenco/ziggy"]
        },
        "jsx": "react-jsx",
        "target": "ES2022",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "types": ["vite/client"],
        "allowImportingTsExtensions": true,
        "noEmit": true,
        "skipLibCheck": true
    },
    "include": ["resources/js/**/*"],
    "exclude": ["node_modules", "public"]
}
